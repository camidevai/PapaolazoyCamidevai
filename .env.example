# EmailJS — https://dashboard.emailjs.com
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here

# WhatsApp — número sin + ni espacios (ej: 56912345678)
WSP_NUMBER_CAMI=56900000000
WSP_NUMBER_PAOLO=56900000001

# Snapwidget — IDs del widget de cada cuenta (https://snapwidget.com)
# Opcional: si no se configuran, el modal muestra un placeholder
SNAP_ID_CAMI=
SNAP_ID_PAPA=
